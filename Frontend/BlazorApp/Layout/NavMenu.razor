            </NavLink>
            <NavLink class="nav-link" href="salles" @onclick="OnNav">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                Salles
            </NavLink>
            <NavLink class="nav-link" href="materiels" @onclick="OnNav">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><polyline points="16 7 16 2 8 2 8 7"/></svg>
                Matériels
            </NavLink>
        </Authorized>
    </AuthorizeView>
</nav>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }

    private async Task OnNav()
    {
        if (OnNavigate.HasDelegate)
            await OnNavigate.InvokeAsync();
    }
}
