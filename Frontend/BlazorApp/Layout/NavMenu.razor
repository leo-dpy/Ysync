@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<div class="nav-brand">
    <span class="brand-y">Y</span><span class="brand-sync">Sync</span>
</div>

<nav class="nav-menu">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="OnNav">
