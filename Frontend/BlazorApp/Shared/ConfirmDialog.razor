@if (Visible)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal-content" @onclick:stopPropagation>
            <h3 class="modal-title">@Title</h3>
            <p class="text-muted">@Message</p>
            <div class="modal-actions">
                <button class="btn btn-ghost" @onclick="Cancel">Annuler</button>
                <button class="btn btn-danger" @onclick="Confirm">Confirmer</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Confirmation";
    [Parameter] public string Message { get; set; } = "Êtes-vous sûr ?";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel() => await OnCancel.InvokeAsync();
}
