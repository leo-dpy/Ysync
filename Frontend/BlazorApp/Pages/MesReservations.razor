@page "/mes-reservations"
@attribute [Authorize]
@inject ReservationsService ReservationsSvc

<PageTitle>Mes réservations — YSync</PageTitle>

<div class="flex-between mb-3">
    <div class="page-header" style="margin-bottom:0">
        <h1 class="page-title">Mes réservations</h1>
        <p class="page-subtitle">Consultez et gérez vos réservations</p>
    </div>
    <a href="/nouvelle-reservation" class="btn btn-primary">+ Nouvelle</a>
</div>

@if (loading)
{
    <p class="text-muted">Chargement...</p>
}
else if (!resas.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <p class="empty-state-text">Vous n'avez aucune réservation</p>
        <a href="/nouvelle-reservation" class="btn btn-primary mt-2">Créer ma première réservation</a>
    </div>
}
else
{
    <div class="grid grid-2">
        @foreach (var r in resas.OrderByDescending(x => x.DateDebut))
        {
            var past = r.DateFin < DateTime.UtcNow;
            <div class="card" style="@(past ? "opacity:0.6" : "")">
                <div class="flex-between mb-1">
                    <h3>@(r.Salle?.Nom ?? r.Materiel?.Nom ?? "Ressource")</h3>
                    <span class="badge @(past ? "badge-warning" : "badge-success")">@(past ? "Passée" : r.Statut)</span>
                </div>
                <p class="text-sm text-muted mb-1"><svg style="display:inline; vertical-align:middle; margin-right:4px;" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>@r.DateDebut.ToString("dd/MM/yyyy HH:mm") → @r.DateFin.ToString("HH:mm")</p>
                @if (r.Salle != null)
                {
                    <p class="text-sm text-muted"><svg style="display:inline; vertical-align:middle; margin-right:4px;" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>@r.Salle.Categorie · @r.Salle.Capacite places</p>
                }
                @if (r.Materiel != null)
                {
                    <p class="text-sm text-muted"><svg style="display:inline; vertical-align:middle; margin-right:4px;" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>@(r.Materiel.Marque ?? "")</p>
                }
                @if (!past)
                {
                    <div class="mt-2">
                        <button class="btn btn-danger btn-sm" @onclick="() => AskCancel(r)">Annuler</button>
                    </div>
                }
            </div>
        }
    </div>
}

<ConfirmDialog Visible="showDel" Title="Annuler la réservation"
    Message="Voulez-vous vraiment annuler cette réservation ?"
    OnConfirm="ConfirmCancel" OnCancel="() => showDel = false" />

@code {
    private List<ReservationDto> resas = new();
    private bool loading = true, showDel;
    private ReservationDto? cancelling;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        try { resas = await ReservationsSvc.GetMesReservationsAsync(); } catch { }
        loading = false;
    }

    private void AskCancel(ReservationDto r) { cancelling = r; showDel = true; }

    private async Task ConfirmCancel()
    {
        showDel = false;
        if (cancelling == null) return;
        try { await ReservationsSvc.DeleteAsync(cancelling.Id); Toast.ShowSuccess("Réservation annulée"); await Load(); }
        catch (ApiException ex) { Toast.ShowError(ex.Message); }
    }
}
