@page "/"
@attribute [Authorize]
@inject SallesService SallesSvc
@inject MaterielsService MaterielsSvc
@inject ReservationsService ReservationsSvc
@inject AuthService AuthSvc

<PageTitle>Dashboard — YSync</PageTitle>

<div class="page-header">
    <h1 class="page-title">Bonjour@(user != null ? $", {user.Nom}" : "") 👋</h1>
    <p class="page-subtitle">Voici un aperçu de vos ressources et réservations</p>
</div>

<div class="grid grid-4 mb-3">
    <div class="stat-card">
        <div class="stat-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg></div>
        <div class="stat-value">@sallesCount</div>
        <div class="stat-label">Salles disponibles</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></div>
        <div class="stat-value">@materielsCount</div>
        <div class="stat-label">Matériels actifs</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <div class="stat-value">@mesResasCount</div>
        <div class="stat-label">Mes réservations</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div class="stat-value">@prochaines</div>
        <div class="stat-label">À venir</div>
    </div>
</div>

@if (mesResas.Any())
{
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Prochaines réservations</h2>
            <a href="/mes-reservations" class="btn btn-ghost btn-sm">Voir tout</a>
        </div>
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Ressource</th>
                        <th>Début</th>
                        <th>Fin</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in mesResas.Take(5))
                    {
                        <tr>
                            <td>@(r.Salle?.Nom ?? r.Materiel?.Nom ?? "—")</td>
                            <td>@r.DateDebut.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@r.DateFin.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge badge-success">@r.Statut</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private UserDto? user;
    private int sallesCount, materielsCount, mesResasCount, prochaines;
    private List<ReservationDto> mesResas = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            user = await AuthSvc.GetCurrentUserAsync();
            var salles = await SallesSvc.GetAllAsync();
            var materiels = await MaterielsSvc.GetAllAsync();
            mesResas = await ReservationsSvc.GetMesReservationsAsync();

            sallesCount = salles.Count;
            materielsCount = materiels.Count;
            mesResasCount = mesResas.Count;
            prochaines = mesResas.Count(r => r.DateDebut > DateTime.Now);
        }
        catch { /* API unavailable */ }
    }
}
