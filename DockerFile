# --- ÉTAPE 1 : Build du Frontend (Blazor WASM) ---
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build-front
WORKDIR /src

# Copie et restauration des dépendances
COPY Frontend/BlazorApp/BlazorApp.csproj Frontend/BlazorApp/
RUN dotnet restore Frontend/BlazorApp/BlazorApp.csproj

# Copie du reste du code et publication
COPY Frontend/BlazorApp/ Frontend/BlazorApp/
WORKDIR /src/Frontend/BlazorApp
RUN dotnet publish BlazorApp.csproj -c Release -o /app/publish

# --- ÉTAPE 2 : Build du Backend (NestJS) ---
FROM node:22-alpine AS build-back
# OpenSSL est indispensable pour le moteur Prisma sur Alpine
RUN apk add --no-cache openssl
RUN npm i -g pnpm
WORKDIR /app

# Installation des dépendances
COPY Backend/ysync/package.json Backend/ysync/pnpm-lock.yaml ./
COPY Backend/ysync/prisma ./prisma
RUN pnpm install --frozen-lockfile

# Copie du code, génération Prisma et build NestJS
COPY Backend/ysync/ ./
RUN npx prisma generate
RUN pnpm build

# --- ÉTAPE 3 : Image finale de production ---
FROM node:22-alpine
# Installation de Nginx, Supervisor pour gérer 2 processus, et OpenSSL
RUN apk add --no-cache nginx supervisor openssl

WORKDIR /app

# Récupération du build Backend
COPY --from=build-back /app/dist ./dist
COPY --from=build-back /app/node_modules ./node_modules
COPY --from=build-back /app/package.json ./
COPY --from=build-back /app/prisma ./prisma

# Récupération du build Frontend (fichiers statiques) vers Nginx
COPY --from=build-front /app/publish/wwwroot /usr/share/nginx/html

# Configuration de Nginx :
# 1. Sert le front sur / et gère le routage SPA (index.html)
# 2. Redirige les appels /api vers le serveur NestJS (port 3000)
RUN printf "server {\n\
    listen 80;\n\
    location / {\n\
        root /usr/share/nginx/html;\n\
        try_files \$uri \$uri/ /index.html;\n\
        types {\n\
            application/wasm wasm;\n\
        }\n\
    }\n\
    location /api/ {\n\
        proxy_pass http://127.0.0.1:3000/;\n\
        proxy_http_version 1.1;\n\
        proxy_set_header Upgrade \$http_upgrade;\n\
        proxy_set_header Connection 'upgrade';\n\
        proxy_set_header Host \$host;\n\
        proxy_cache_bypass \$http_upgrade;\n\
        proxy_set_header X-Real-IP \$remote_addr;\n\
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;\n\
    }\n\
}\n" > /etc/nginx/http.d/default.conf

# Configuration de Supervisor pour lancer Node et Nginx en parallèle
# Les logs sont redirigés vers stdout pour être visibles dans Coolify
RUN printf "[supervisord]\n\
nodaemon=true\n\
user=root\n\n\
[program:node]\n\
command=node dist/main\n\
directory=/app\n\
autostart=true\n\
autorestart=true\n\
stdout_logfile=/dev/stdout\n\
stdout_logfile_maxbytes=0\n\
stderr_logfile=/dev/stderr\n\
stderr_logfile_maxbytes=0\n\n\
[program:nginx]\n\
command=nginx -g 'daemon off;'\n\
autostart=true\n\
autorestart=true\n\
stdout_logfile=/dev/stdout\n\
stdout_logfile_maxbytes=0\n\
stderr_logfile=/dev/stderr\n\
stderr_logfile_maxbytes=0\n" > /etc/supervisord.conf

# Exposition du port web standard
EXPOSE 80

# Lancement de Supervisor
CMD ["supervisord", "-c", "/etc/supervisord.conf"]